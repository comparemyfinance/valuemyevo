{
  "name": "evoworth",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "setup:windows": "powershell -ExecutionPolicy Bypass -File .\\scripts\\setup.ps1",
    "dev": "powershell -ExecutionPolicy Bypass -File .\\scripts\\dev.ps1",
    "dev:web": "npm --workspace @evoworth/web run dev",
    "build:web": "npm --workspace @evoworth/web run build",
    "start:web": "npm --workspace @evoworth/web run start",
    "lint:web": "npm --workspace @evoworth/web run lint",
    "test:api": "powershell -ExecutionPolicy Bypass -File .\\scripts\\test-api.ps1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

